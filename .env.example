# Copy to .env and fill in. .env is gitignored.
#
# Bring up the local-db profile so docker-compose runs an in-cluster
# postgres for development. Production unsets this and points DATABASE_URL
# at the DigitalOcean managed cluster instead.
COMPOSE_PROFILES=local-db

# Local dev (against the docker-compose `db` service):
DATABASE_URL=postgres://whi:whi@db:5432/whi?sslmode=disable

# JWT signing secret (HS256). Generate with: openssl rand -base64 48
# In prod, set this from a real secret store; do NOT reuse the dev value.
WHI_JWT_SECRET=dev-only-do-not-use-this-in-production-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Backend port (inside the container; docker-compose maps it).
PORT=3000

# Idle game sweep (seconds) — unchanged from before.
WHI_IDLE_TTL_SECONDS=300

# Debug protocol channel. Off by default; never enable in production.
WHI_DEBUG=0
WHI_ALLOW_OVERWRITE=0

# Admin endpoints (currently: deploy maintenance window). Unset = the
# /api/admin/* routes are disabled. In prod, set this to a long random
# secret and pass it as `Authorization: Bearer …` from the deploy
# pipeline.
WHI_ADMIN_TOKEN=
