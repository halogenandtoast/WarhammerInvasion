# Copy to terraform.tfvars and edit. Do NOT commit terraform.tfvars.

# DigitalOcean API token. Prefer `export DIGITALOCEAN_TOKEN=...` and omit this.
do_token = "dop_v1_..."

# Authorize a key on the droplet. Pick ONE of:
#
# A) Reference a key already uploaded to your DO account (run
#    `doctl compute ssh-key list` to find the name):
# ssh_key_name = "my-laptop"
#
# B) Or upload a new key. Paste the contents of ~/.ssh/id_ed25519.pub:
# ssh_public_key = "ssh-ed25519 AAAA... you@host"

# Git URL the droplet clones on first boot. Public repo or a URL that embeds
# a deploy token — there is no SSH agent forwarding into the droplet.
repo_url    = "https://github.com/youruser/WarhammerInvasion.git"
repo_branch = "main"

# Optional tweaks.
# region            = "nyc3"
# droplet_size      = "s-2vcpu-2gb"
# ssh_allowed_cidrs = ["203.0.113.4/32"]
# whi_debug         = "0"

# --- AWS (card-asset CDN) ----------------------------------------------------
# AWS credentials are read from the standard provider chain (env vars, shared
# config, instance profile) — don't set them here.
# aws_region         = "us-east-1"
# assets_bucket_name = "warhammer-invasion-assets"
